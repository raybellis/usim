{
	"name": "usim",
	"version": "1.0.1",
	"keywords": "emulation, mc6809, mos6502",
	"description": "USim 6502 / 6809 emulator framework",
	"authors": {
		"name": "Ray Bellis",
		"maintainer": true
	},
	"license": "MPL-2.0",
	"frameworks": "*",
	"platforms": "*",
	"repository": {
		"type": "git",
		"url": "https://github.com/raybellis/usim.git"
	},
	"headers": [
		"core/usim.h",
		"cpu/6809/mc6809.h",
		"cpu/65xx/mos6502.h",
		"cpu/65xx/base65c02.h",
		"peripherals/mc6850.h"
	],
	"build": {
		"flags": [
			"-I.",
			"-Icore",
			"-Icpu/6809",
			"-Icpu/65xx",
			"-Iperipherals"
		],
		"includeDir": ".",
		"srcDir": ".",
		"srcFilter": [
			"+<core/usim.cpp>",
			"+<core/memory.cpp>",
			"+<cpu/6809/mc6809.cpp>",
			"+<cpu/6809/mc6809in.cpp>",
			"+<cpu/65xx/mos6502.cpp>",
			"+<cpu/65xx/mos6502in.cpp>",
			"+<cpu/65xx/base65c02.cpp>",
			"+<peripherals/mc6850.cpp>"
		]
	}
}
